{
  "info": {
    "name": "OpsFlow Demo Flow",
    "_postman_id": "b7f08db5-d6f1-4cb4-a02d-6a8f2fb6a8ec",
    "description": "Demo end-to-end flow for cash movements and cashflow stats. Uses Bearer JWT access tokens and refresh_token HttpOnly cookie for /auth/refresh.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Login Admin",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        },
        "description": "Login admin user and store adminAccessToken."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('adminAccessToken', json.accessToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "2) Auth Me",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{adminAccessToken}}", "type": "string" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "me"]
        },
        "description": "Validate current admin session context."
      }
    },
    {
      "name": "3) List Branches",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{adminAccessToken}}", "type": "string" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/branches",
          "host": ["{{baseUrl}}"],
          "path": ["branches"]
        },
        "description": "List branches for current organization as admin."
      }
    },
    {
      "name": "4) Login Operator",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{operatorEmail}}\",\n  \"password\": \"{{operatorPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        },
        "description": "Login operator for branch-scoped create flow."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('operatorAccessToken', json.accessToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "5) Operator Creates Cash Movement",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{operatorAccessToken}}", "type": "string" }
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": \"1250.00\",\n  \"type\": \"OUT\",\n  \"currency\": \"ARS\",\n  \"description\": \"Demo operator payment\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/cash-movements",
          "host": ["{{baseUrl}}"],
          "path": ["cash-movements"]
        },
        "description": "Creates movement with OPERATOR scope (branch inferred from token)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('cashMovementId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "6) Login Manager",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{managerEmail}}\",\n  \"password\": \"{{managerPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        },
        "description": "Login manager for approval and delivery workflow."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('managerAccessToken', json.accessToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "7) Manager Approves",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{managerAccessToken}}", "type": "string" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/cash-movements/{{cashMovementId}}/approve",
          "host": ["{{baseUrl}}"],
          "path": ["cash-movements", "{{cashMovementId}}", "approve"]
        },
        "description": "Approve pending movement."
      }
    },
    {
      "name": "8) Manager Delivers",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{managerAccessToken}}", "type": "string" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/cash-movements/{{cashMovementId}}/deliver",
          "host": ["{{baseUrl}}"],
          "path": ["cash-movements", "{{cashMovementId}}", "deliver"]
        },
        "description": "Deliver approved movement."
      }
    },
    {
      "name": "9) Stats Dashboard",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{managerAccessToken}}", "type": "string" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/cashflow/stats",
          "host": ["{{baseUrl}}"],
          "path": ["cashflow", "stats"]
        },
        "description": "Read dashboard cards (totals and workflow counters)."
      }
    },
    {
      "name": "10) Get CSRF Token",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/auth/csrf",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "csrf"]
        },
        "description": "Gets csrf_token cookie. Required before /auth/refresh when CSRF protection is enabled."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var csrfToken = pm.cookies.get('csrf_token');",
              "if (csrfToken) { pm.collectionVariables.set('csrfToken', csrfToken); }"
            ]
          }
        }
      ]
    },
    {
      "name": "11) Refresh Access Token",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-csrf-token", "value": "{{csrfToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "refresh"]
        },
        "description": "Uses refresh_token HttpOnly cookie + csrf token header."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  var json = pm.response.json();",
              "  pm.collectionVariables.set('accessToken', json.accessToken);",
              "}"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "adminEmail", "value": "demo.admin@pacifictreasury.local" },
    { "key": "adminPassword", "value": "Demo1234!" },
    { "key": "managerEmail", "value": "demo.manager@pacifictreasury.local" },
    { "key": "managerPassword", "value": "Demo1234!" },
    { "key": "operatorEmail", "value": "demo.operator@pacifictreasury.local" },
    { "key": "operatorPassword", "value": "Demo1234!" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "managerAccessToken", "value": "" },
    { "key": "operatorAccessToken", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "cashMovementId", "value": "" },
    { "key": "csrfToken", "value": "" }
  ]
}
